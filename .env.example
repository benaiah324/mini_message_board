SERVER_PORT=3000

# Local / Render Postgres connection settings
DB_USER="your_render_db_user"
DB_HOST="your_render_db_host"
DB_DATABASE_NAME="your_render_db_name"
DB_PORT=5432
DB_PASSWORD="your_render_db_password"

# Render usually provides this automatically.
# If you prefer to use the full connection string, fill this in instead.
DATABASE_URL="postgres://your_render_db_user:your_render_db_password@your_render_db_host:5432/your_render_db_name"

# Render deployment note:
# Set NODE_ENV=production in the Render service environment.
