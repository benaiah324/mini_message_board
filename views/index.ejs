<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/styles-index.css" />
    <title>Portfolio Message Board</title>
</head>

<body>
    <main class="page-shell">
        <section class="hero-card">
            <p class="eyebrow">Portfolio Project</p>
            <h1>Mini Message Board</h1>
            <p class="hero-copy">A polished full-stack message board with a clean portfolio-ready interface, quick
                insights, and simple message management.</p>
            <div class="chip-row">
                <span class="chip">Express + PostgreSQL</span>
                <span class="chip">Responsive UI</span>
                <span class="chip">Message insights</span>
            </div>
        </section>

        <section class="stats-grid">
            <article class="stat-card">
                <strong>
                    <%= messageCount %>
                </strong>
                <span>Total messages</span>
            </article>
            <article class="stat-card">
                <strong>
                    <%= latestMessage ? latestMessage.author : '—' %>
                </strong>
                <span>Latest contributor</span>
            </article>
            <article class="stat-card">
                <strong>
                    <%= latestMessage ? new Date(latestMessage.created_at).toLocaleDateString() : '—' %>
                </strong>
                <span>Latest post</span>
            </article>
        </section>

        <section class="content-card">
            <div class="content-heading">
                <div>
                    <p class="eyebrow">Live board</p>
                    <h2>Recent messages</h2>
                </div>
                <button class="btn-new-message" onclick="window.location.href='/api/new'">Add a message</button>
            </div>

            <% if (messages.length===0) { %>
                <p class="empty-state">No messages yet. Be the first to add one to this portfolio demo.</p>
                <% } else { %>
                    <div class="message-grid">
                        <% messages.forEach(message=> { %>
                            <article class="message-card">
                                <p class="message-text">“<%= message.text %>”</p>
                                <div class="message-meta">
                                    <span>By <strong>
                                            <%= message.author %>
                                        </strong></span>
                                    <span>
                                        <%= new Date(message.created_at).toLocaleString() %>
                                    </span>
                                </div>
                                <div class="btn-option">
                                    <form method="POST" action="/api/delete/<%= message.id %>">
                                        <button type="submit" class="ghost-btn">Delete</button>
                                    </form>
                                    <a class="link-btn" href="/api/message/<%= message.id %>">Open</a>
                                </div>
                            </article>
                            <% }) %>
                    </div>
                    <% } %>
        </section>
    </main>
</body>

</html>