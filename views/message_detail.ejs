<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="/styles-index.css">
</head>

<body>
    <h1>Message Detail</h1>
    <div class="container">
        <div class="messages">
            <div class="mess">
                <h4>Message:</h4>
                <p>
                    <%= message.text %>
                </p>
            </div>
            <div class="mess">
                <h4>User:</h4>
                <p>
                    <%= message.author %>
                </p>
            </div>
            <div class="mess">
                <h4>Date:</h4>
                <p>
                    <%= message.created_at %>
                </p>
            </div>
        </div>

        <button class="btn-new-message" onclick="window.location.href='/api'">Back to messages</button>
    </div>
</body>

</html>