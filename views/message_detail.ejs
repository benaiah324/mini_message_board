<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="/styles-index.css" />
</head>

<body>
    <main class="page-shell detail-shell">
        <section class="content-card detail-card">
            <p class="eyebrow">Message detail</p>
            <h1>Message snapshot</h1>
            <article class="message-card detail-message">
                <p class="message-text">“<%= message.text %>”</p>
                <div class="message-meta">
                    <span>By <strong>
                            <%= message.author %>
                        </strong></span>
                    <span>
                        <%= new Date(message.created_at).toLocaleString() %>
                    </span>
                </div>
            </article>
            <button class="btn-new-message" onclick="window.location.href='/api'">Back to board</button>
        </section>
    </main>
</body>

</html>